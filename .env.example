# Luna Streams Configuration
STREAMS_HOST=0.0.0.0
STREAMS_PORT=8100
STREAMS_LOG_LEVEL=info

# State persistence
STREAMS_STATE_DIR=/app/state
STREAMS_MODEL_DIR=/app/models
STREAMS_AUTO_SAVE_INTERVAL_SEC=300
STREAMS_SNAPSHOT_RETENTION=3

# GGUF inference (llama.cpp)
STREAMS_GGUF_MODEL=mamba-370m/mamba-370m-q8_0.gguf
STREAMS_GGUF_N_CTX=256
STREAMS_GGUF_N_THREADS=8

# EMA buffer
STREAMS_EMA_DECAY=0.999
STREAMS_DELTA_THRESHOLD=0.01

# Qwen bridge (Option B - text summaries via Ollama)
STREAMS_QWEN_OLLAMA_URL=http://10.0.0.30:11434
STREAMS_QWEN_MODEL=qwen3.5:9b

# CPU tuning
OMP_NUM_THREADS=8
